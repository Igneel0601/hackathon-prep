#!/usr/bin/env sh
# Block a push when an API route changed but its mirrored doc didn't.
# Doc convention: src/app/api/<path>/route.ts  ->  docs/apis/<path>/route.md
# Bypass in a real emergency with: git push --no-verify

# Compare against origin/main; fall back to the whole history on first push.
if git rev-parse --verify origin/main >/dev/null 2>&1; then
  range="origin/main...HEAD"
else
  range="HEAD"
fi

changed=$(git diff --name-only "$range" 2>/dev/null)

routes=$(echo "$changed" | grep -E '^src/app/api/.*/route\.(ts|tsx|js)$' || true)
docs=$(echo "$changed"   | grep -E '^docs/apis/' || true)

if [ -n "$routes" ] && [ -z "$docs" ]; then
  echo ""
  echo "✖ PUSH BLOCKED — API route(s) changed but no doc under docs/apis/ was updated:"
  echo "$routes" | sed 's/^/    /'
  echo ""
  echo "  Update the mirrored doc (src/app/api/X/route.ts -> docs/apis/X/route.md),"
  echo "  or bypass with: git push --no-verify"
  echo ""
  exit 1
fi

# Fast type safety gate (no full build — that runs in CI).
echo "→ typecheck (tsc --noEmit)…"
if ! pnpm -s typecheck; then
  echo ""
  echo "✖ PUSH BLOCKED — TypeScript errors above. Fix them, or bypass with: git push --no-verify"
  exit 1
fi

exit 0
