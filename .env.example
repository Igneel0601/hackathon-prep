# Copy to .env and fill in. Never commit .env (it's gitignored).
#
# Neon Postgres: create a project at https://neon.tech, copy the connection string.
# Use the POOLED connection string for the app (host has "-pooler"),
# and the DIRECT (non-pooled) string for migrations if Neon gives you one.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: direct (non-pooled) URL for `prisma migrate`. Wire into prisma.config.ts if used.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── Auth.js (NextAuth v5) ───
# Generate a secret: `npx auth secret`  (or: openssl rand -base64 33)
AUTH_SECRET=""

# GitHub OAuth app: https://github.com/settings/developers
# Callback URL (dev): http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
