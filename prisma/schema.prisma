// Prisma schema — source of truth for the DB.
// Models here -> run `pnpm db:migrate` to create/apply a migration.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js (NextAuth) models ───────────────────────────────────────────────
// Required by @auth/prisma-adapter. Extend User with app fields as needed.
// Ref: https://authjs.dev/getting-started/adapters/prisma

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // bcrypt hash for email/password login; null for OAuth-only users
  role          Role         @default(EMPLOYEE)
  active        Boolean      @default(true) // archived users (active=false) can't log in
  accounts      Account[]
  sessions      Session[]
  posSessions   PosSession[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Odoo Cafe POS — domain models ───────────────────────────────────────────
// See docs/SCOPE.md (MVP) + docs/brief/odoo-cafe-pos.pdf. Money is Decimal(10,2)
// to avoid float rounding at checkout. OrderItem snapshots name/price so editing
// a Product later never rewrites past orders.

enum Role {
  ADMIN // user/admin — configures the backend
  EMPLOYEE // cashier — operates the POS terminal
}

enum OrderStatus {
  DRAFT
  PAID
  CANCELLED
}

enum KitchenStatus {
  NONE // not sent to kitchen yet
  TO_COOK
  PREPARING
  COMPLETED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

// Admin-configurable per-method settings (one row per method). Drives which
// methods the POS checkout offers; UPI needs a saved upiId to render its QR.
model PaymentMethodSetting {
  method    PaymentMethod @id
  enabled   Boolean       @default(true)
  upiId     String? // e.g. "cafe@okhdfc" — required when UPI is enabled
  label     String? // optional display override
  updatedAt DateTime      @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#6b7280") // shows on POS tabs/cards (spec 2.3)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  name          String
  price         Decimal     @db.Decimal(10, 2)
  unit          String      @default("piece") // per piece / kg / litre (spec 2.2)
  tax           Decimal     @default(0) @db.Decimal(5, 2) // percent
  description   String?
  sendToKitchen Boolean     @default(true) // only these show on the KDS (spec 4)
  active        Boolean     @default(true)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([categoryId])
}

model Floor {
  id        String   @id @default(cuid())
  name      String
  tables    Table[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id        String   @id @default(cuid())
  number    Int
  seats     Int      @default(4)
  active    Boolean  @default(true)
  floorId   String
  floor     Floor    @relation(fields: [floorId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([floorId, number])
  @@index([floorId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A cashier's shift. Opens on login, groups its orders, closes at end of shift (spec 2.8).
model PosSession {
  id        String    @id @default(cuid())
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

// The central entity + the shared A↔B contract (see docs/TEAM.md).
// `status` = payment lifecycle; `kitchenStatus` = cooking progress. They move independently.
model Order {
  id            String        @id @default(cuid())
  number        Int           @unique @default(autoincrement()) // human-facing order/ticket #
  status        OrderStatus   @default(DRAFT)
  kitchenStatus KitchenStatus @default(NONE)
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @default(0) @db.Decimal(10, 2)
  tableId       String
  table         Table         @relation(fields: [tableId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  sessionId     String
  session       PosSession    @relation(fields: [sessionId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tableId])
  @@index([sessionId])
  @@index([status])
}

// Line snapshot — name + unitPrice frozen at add-time so product edits don't rewrite history.
model OrderItem {
  id            String        @id @default(cuid())
  name          String
  unitPrice     Decimal       @db.Decimal(10, 2)
  qty           Int           @default(1)
  lineTotal     Decimal       @db.Decimal(10, 2)
  round         Int           @default(0) // 0 = in cart (un-fired); 1+ = kitchen fire batch
  kitchenStatus KitchenStatus @default(NONE) // per-item cooking state (rounds fire independently)
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  createdAt     DateTime      @default(now())

  @@index([orderId])
  @@index([kitchenStatus])
}

model Payment {
  id        String        @id @default(cuid())
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  reference String? // card txn ref / UPI note (simulated in MVP)
  changeDue Decimal?      @db.Decimal(10, 2) // cash only
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([orderId])
}
